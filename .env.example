# PocketBase is pinned for reproducible schema behavior. The setup scripts use
# this default when PB_VERSION is not already set.
PB_VERSION=0.39.6

# Local browser/API origin. Do not put credentials in VITE_ or other values
# compiled into the public client bundle.
LINECHECK_ORIGIN=http://127.0.0.1:8090

# Deployment-only examples; leave secrets in the host's secret store.
# LINECHECK_BACKUP_DIR=/var/backups/linecheck
# LINECHECK_TRUST_PROXY=false

